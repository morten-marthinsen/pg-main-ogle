{
  "mcpServers": {
    "figma": {
      "url": "https://mcp.figma.com/mcp"
    },
    "clickup": {
      "command": "npx",
      "args": ["-y", "@hauptsache.net/clickup-mcp@latest"],
      "env": {
        "CLICKUP_MCP_MODE": "read",
        "CLICKUP_API_TOKEN": "${CLICKUP_API_TOKEN}"
      }
    },
    "google-docs": {
      "command": "npx",
      "args": ["-y", "@a-bonus/google-docs-mcp"]
    },
    "fathom": {
      "command": "npx",
      "args": ["-y", "fathom-mcp"]
    },
    "miro": {
      "command": "npx",
      "args": ["-y", "miro-mcp"],
      "env": {
        "MIRO_API_TOKEN": "${MIRO_API_TOKEN}"
      }
    }
  }
}
