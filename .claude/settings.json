{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_TASK_LIST_ID": "pg-main"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "_performance-golf/pg-marketing-os/.hooks/reset-token-state.sh"
          },
          {
            "type": "command",
            "command": "_performance-golf/pg-creative-os/.hooks/reset-token-state.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/copy-principles-enforcer.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/copy-post-audit.sh"
          },
          {
            "type": "command",
            "command": "_performance-golf/pg-marketing-os/.hooks/dispatch-validator.sh"
          },
          {
            "type": "command",
            "command": "_performance-golf/pg-creative-os/.hooks/dispatch-validator.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "_performance-golf/pg-marketing-os/.hooks/dispatch-validator.sh --final-check"
          },
          {
            "type": "command",
            "command": "_performance-golf/pg-creative-os/.hooks/dispatch-validator.sh --final-check"
          }
        ]
      }
    ]
  }
}
