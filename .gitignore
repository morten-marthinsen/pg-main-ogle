# ========== DEV BUILD OUTPUTS ==========
**/node_modules/
**/node_modules.nosync/
**/node_modules
**/.next/
**/.nuxt/
**/dist/
**/build/
**/.git/

# ========== CLAUDE CODE - LOCAL SETTINGS ==========
.claude/settings.local.json
.claude/memory
.claude/statusline-command.sh

# ========== SECURITY - NEVER COMMIT ==========
.env
.env.*
*.pem
*.key
**/credentials*.json
**/secrets*.json
**/token*.json

# ========== LOCAL-ONLY (not shared with team) ==========
**/daily-reports.nosync/

# ========== LARGE FILES / LOGS ==========
*.log
*.zip
*.rar
*.7z
*.tar.gz

# ========== KEYNOTE BACKUPS ==========
*.key.backup

# ========== LARGE MEDIA (keep repo size manageable) ==========
*.pdf
*.mp4
*.mov
*.mp3
*.wav
*.dmg
*.pkg

# ========== HOOK RUNTIME STATE ==========
**/.hooks/.reminder-state.json
**/.hooks/.token-estimator-state.json

# ========== PYTHON ==========
__pycache__/
*.pyc

# ========== OS / SYSTEM ==========
.DS_Store
Thumbs.db
*.swp
*~
__MACOSX/
*.textClipping
*.webloc

# ========== PLAYWRIGHT MCP (local browser automation artifacts) ==========
.playwright-mcp/

# ========== ROOT MCP CONFIG (shared — uses ${ENV_VAR} references, no secrets) ==========
# .mcp.json is committed. Team members set API keys as env vars on their machine.

# ========== DATA SERVICE LOCAL SCRATCH ==========
_performance-golf/pg-data-service/_local/
