# Static Ad Delivery Pipeline — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in the values below.
# DO NOT commit the .env file to git.
#
#   cp env.template .env
#
# Then open .env in any text editor and replace each placeholder.

# ── ClickUp API Token ────────────────────────────────
# Where to get it:
#   1. Log in to ClickUp (app.clickup.com)
#   2. Click your avatar (bottom-left) → Settings
#   3. Click "Apps" in the left sidebar
#   4. Under "API Token", click "Generate" (or copy your existing token)
#   5. Paste the token below (starts with "pk_")
CLICKUP_API_TOKEN=pk_YOUR_TOKEN_HERE

# ── Iconik Credentials ───────────────────────────────
# Where to get it:
#   1. Log in to Iconik (app.iconik.io)
#   2. Click your avatar → Admin
#   3. Go to "API" → "Application Tokens"
#   4. Create a new application token (or ask Christopher for the shared values)
#   5. Copy the App ID (UUID format) and Auth Token (long string)
ICONIK_APP_ID=
ICONIK_AUTH_TOKEN=

# ── Iconik Metadata View ID ─────────────────────────
# Ask Christopher for this value if needed.
ICONIK_METADATA_VIEW_ID=

# ── NLC Parent Collection ID ────────────────────────
# This is the UUID of the "No Limit Creative" parent collection in Iconik.
# All new subcollections for deliveries are created under this folder.
# Ask Christopher for this value.
NLC_PARENT_COLLECTION_ID=
