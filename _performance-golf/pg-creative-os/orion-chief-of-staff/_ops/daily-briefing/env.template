# Daily Executive Briefing — Environment Variables
# =================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git.

# Anthropic API (for AI analysis in modules)
ANTHROPIC_API_KEY=sk-ant-...

# ClickUp API (for M7 inbox, M1 automation scanner, production sync)
CLICKUP_API_TOKEN=pk_...
CLICKUP_WORKSPACE_ID=

# Gmail OAuth (for M2 industry intel, M6 newsletter digest)
# These paths are relative to the daily-briefing directory.
# The auth/ directory is created by the setup scripts.
GMAIL_CREDENTIALS_PATH=auth/credentials.json
GMAIL_TOKEN_PATH=auth/gmail_token.json

# Google Calendar OAuth (for M12 daily schedule)
CALENDAR_CREDENTIALS_PATH=auth/credentials.json
CALENDAR_TOKEN_PATH=auth/calendar_token.json

# Google Sheets OAuth (for CLM sync module)
SHEETS_CREDENTIALS_PATH=auth/credentials.json
SHEETS_TOKEN_PATH=auth/sheets_token.json

# Slack OAuth (for M4 slack monitor, M5 wise reply context)
# Create a Slack app and get these from Basic Information + OAuth pages.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_TOKEN_PATH=auth/slack_token.json

# Notifications — Slack incoming webhook for daily report delivery
# Create at: https://api.slack.com/messaging/webhooks
# IMPORTANT: Use a DM or private channel — never a shared/public channel.
SLACK_WEBHOOK_URL=

# Optional: Working relationships directory for M5 (Wise Reply Context)
# Defaults to ~/.claude/memory/working-relationships/ if not set.
# WORKING_RELATIONSHIPS_DIR=
