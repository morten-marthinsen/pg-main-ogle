      "speed_mentioned": null,
      "priority": "STANDARD"
    },
    {
      "id": "SPD-025",
      "quote": "Ground reaction forces are your secret weapon for adding power to your swing. By pushing against the ground with your feet during the downswing, you generate upward force that can be transferred through your body and into the clubhead.",
      "bucket": "LEARNING_AND_IMPROVEMENT",
      "physical_tag": "speed_training",
      "emotional_tags": ["technique", "power_source", "physics"],
      "source": "https://www.oneclubtrainer.com/blogs/news/unlocking-the-secrets-to-explosive-swing-speed-a-complete-guide",
      "speed_mentioned": null,
      "priority": "HIGH"
    },
    {
      "id": "SPD-026",
      "quote": "Remember, increasing your swing speed is not an overnight feat but a journey of continuous improvement and dedication.",
      "bucket": "LEARNING_AND_IMPROVEMENT",
