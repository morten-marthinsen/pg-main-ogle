      "speed_mentioned": null,
      "priority": "STANDARD"
    },
    {
      "id": "SPD-023",
      "quote": "Increasing your swing speed does wonders for your game. It allows for longer drives, shorter approaches, and the ability to overcome challenges like headwinds more effectively.",
      "bucket": "PERFORMANCE_GOALS",
      "physical_tag": "speed_goals",
      "emotional_tags": ["game_improvement", "versatility", "confidence"],
