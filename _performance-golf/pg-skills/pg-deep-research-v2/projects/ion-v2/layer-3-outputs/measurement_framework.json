      "format": "Comprehensive presentation"
    },
    "quarterly_review": {
      "description": "Strategic review and planning",
      "sections": [
        "Quarter performance vs. plan",
        "Strategy effectiveness assessment",
        "Market and competitive analysis",
        "Customer insights deep dive",
        "Learnings documentation",
        "Next quarter strategy and plan"
      ],
      "audience": "Executive team",
      "format": "Executive presentation with appendix"
    }
  },
  "measurement_infrastructure": {
    "data_sources": {
      "web_analytics": {
        "tool": "Google Analytics 4",
        "purpose": "Website behavior, conversion tracking",
        "integration": "GTM, e-commerce tracking"
      },
      "advertising_platforms": {
        "tools": ["Meta Ads Manager", "Google Ads", "TikTok Ads"],
        "purpose": "Campaign performance, attribution",
        "integration": "Pixel/tag implementation"
      },
      "ecommerce_platform": {
        "tool": "Shopify/BigCommerce",
        "purpose": "Transaction data, customer records",
        "integration": "Native analytics, data exports"
      },
      "crm": {
        "tool": "Klaviyo/HubSpot",
        "purpose": "Customer data, email performance",
        "integration": "E-commerce sync, segmentation"
      },
      "social_media": {
        "tools": ["Native analytics", "Sprout Social"],
        "purpose": "Social performance, engagement",
        "integration": "API connections"
      },
      "social_listening": {
        "tool": "Brandwatch/Sprinklr",
        "purpose": "Brand mentions, sentiment, SOV",
        "integration": "Automated monitoring"
      },
      "survey_platform": {
