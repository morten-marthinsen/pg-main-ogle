      "description": "Always-on monitoring for operational metrics",
      "metrics": [
        "Website traffic",
        "Conversion rate",
        "Revenue",
        "Ad spend and ROAS",
        "Cart abandonment",
        "Customer service volume"
      ],
      "access": "Marketing team, leadership",
      "alerts": "Automated for threshold breaches"
    },
    "daily_report": {
      "description": "Quick operational check-in",
      "metrics": [
        "Revenue vs. target",
        "New customers",
        "Top performing content/ads",
        "Any issues or alerts"
      ],
      "audience": "Marketing team",
      "format": "Automated email summary"
    },
