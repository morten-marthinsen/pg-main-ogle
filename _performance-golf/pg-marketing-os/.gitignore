# Personal/internal directories — never share outside vault
~brain/
~system/

# Project outputs (per-run artifacts, not engine code)
outputs/*/
!outputs/.gitkeep

# Engine-internal research outputs (non-engine, per-project artifacts)
00-deep-research/outputs/

# Test results
tests/results/
!tests/.gitkeep

# Hook runtime state (machine-specific, absolute paths)
.hooks/.reminder-state.json
.hooks/.token-estimator-state.json
